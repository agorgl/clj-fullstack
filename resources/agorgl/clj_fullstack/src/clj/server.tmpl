(ns {{top/ns}}.{{main/ns}}.server
  (:require
   [io.pedestal.http :as http]
   [{{top/ns}}.{{main/ns}}.service :as service]))

(defonce server nil)

(defn init
  "Constructs the current server."
  []
  (alter-var-root
   #'server
   (fn [_]
     (-> (service/service-map nil)
         http/create-server))))

(defn start
  "Starts the current server."
  []
  (alter-var-root
   #'server
   (fn [server]
     (when server
       (http/start server)))))

(defn stop
  "Shuts down the current server."
  []
  (alter-var-root
   #'server
   (fn [server]
     (when server
       (http/stop server)))))

(defn go
  "Initializes the current server and starts it running."
  []
  (init)
  (start))
